VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase Web app config — from Firebase console → Project settings → Add app → Web
# (the existing pragati-bandhu project only has an Android app registered so far;
# this needs a separate Web app added to get these values)
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=pragati-bandhu.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pragati-bandhu
VITE_FIREBASE_APP_ID=your_firebase_web_app_id
